# Database
DATABASE_URL=postgresql+asyncpg://memoryai:memoryai@localhost:5432/memoryai

# Comma-separated list of allowed origins for backend CORS.
# Use * only for local experiments, never for production.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:5173,http://127.0.0.1:5173

# JWT Secret (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here-replace-in-production

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# S3/MinIO Storage (local development)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=your-minio-access-key
S3_SECRET_KEY=your-minio-secret-key
S3_BUCKET=memory-ai
S3_REGION=us-east-1

# Redis
REDIS_URL=redis://localhost:6379

# Vector Database (set to true to use Pinecone instead of pgvector)
USE_PINECONE=false
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=memory-ai

# Google OAuth (for Google Sign-In on iOS/Android and web)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gmail API (preferred email transport — no app password needed)
# Run scripts/get_gmail_token.py once to obtain the refresh token.
GMAIL_REFRESH_TOKEN=

# Gmail SMTP via App Password (simplest setup — recommended for dev and production)
# How to generate an App Password:
#   1. myaccount.google.com → Security → 2-Step Verification (must be ON)
#   2. Search "App passwords" → create one for Mail + Other (name it "DukiAI Memory")
#   3. Copy the 16-char password (spaces optional) into SMTP_PASSWORD below
# Leave SMTP_HOST empty to fall through to console logging in DEBUG mode.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourname@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM=yourname@gmail.com

# Set to true to require email verification on personal-email registrations.
# Google Sign-In users are always verified immediately.
EMAIL_VERIFICATION_ENABLED=false

# Backend public URL — used in verification email links
BACKEND_URL=http://localhost:8000

# App Settings
DEBUG=false
