# Database
DATABASE_URL=postgresql+asyncpg://memoryai:dev_password_change_me@localhost:5432/memoryai

# JWT Secret (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here-replace-in-production

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# S3/MinIO Storage (local development)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=memory-ai
S3_REGION=us-east-1

# Redis
REDIS_URL=redis://localhost:6379

# Vector Database (set to true to use Pinecone instead of pgvector)
USE_PINECONE=false
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=memory-ai

# App Settings
DEBUG=true
