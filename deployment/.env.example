# ─────────────────────────────────────────────────────────────────────────────
#  Memory AI — Production Environment Variables
#  Copy to .env and fill in all values before running deploy.sh
# ─────────────────────────────────────────────────────────────────────────────

# ── Domain & SSL ──────────────────────────────────────────────────────────────
DOMAIN=api.dukiai.com          # Your API subdomain (DNS A record → Droplet IP)
FRONTEND_ORIGINS=https://dukiai.com,https://app.dukiai.com

# ── FastAPI App ───────────────────────────────────────────────────────────────
SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_STRING  # openssl rand -hex 32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200           # 30 days
REFRESH_TOKEN_EXPIRE_DAYS=90
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=memoryai
POSTGRES_USER=memoryai
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://memoryai:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/memoryai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD
REDIS_URL=redis://:REPLACE_WITH_REDIS_PASSWORD@redis:6379/0

# ── MinIO (object storage) ────────────────────────────────────────────────────
MINIO_ROOT_USER=memoryai
MINIO_ROOT_PASSWORD=REPLACE_WITH_MINIO_PASSWORD
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_NAME=memories
MINIO_USE_SSL=false          # true if MinIO is behind HTTPS

# Alternatively, use DigitalOcean Spaces (S3-compatible):
# MINIO_ENDPOINT=nyc3.digitaloceanspaces.com
# MINIO_ACCESS_KEY=DO_SPACES_KEY
# MINIO_SECRET_KEY=DO_SPACES_SECRET
# MINIO_BUCKET_NAME=memoryai-prod
# MINIO_USE_SSL=true

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini          # Cost-optimised for production
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Whisper (voice transcription) ────────────────────────────────────────────
WHISPER_MODEL=whisper-1            # OpenAI Whisper API (set USE_LOCAL_WHISPER=false)
USE_LOCAL_WHISPER=false

# ── Email — for auth verification emails ─────────────────────────────────────
# Set EMAIL_VERIFICATION_ENABLED=true and supply at least one transport below.
EMAIL_VERIFICATION_ENABLED=true
SMTP_FROM=yourname@gmail.com

# Gmail API (preferred for heavy volume) — obtain via Google Cloud Console OAuth2 flow
GMAIL_REFRESH_TOKEN=REPLACE_WITH_GMAIL_REFRESH_TOKEN

# Gmail SMTP via App Password (recommended for most deployments)
# How to generate an App Password:
#   1. myaccount.google.com → Security → 2-Step Verification (must be ON)
#   2. Search "App passwords" → create for Mail + Other (name it "Memory AI")
#   3. Paste the 16-char password below (spaces optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourname@gmail.com
SMTP_PASSWORD=REPLACE_WITH_GMAIL_APP_PASSWORD

# Public URL of the backend — used in verification links
BACKEND_URL=https://api.memory-ai.app

# ── Sentry (optional — error tracking) ───────────────────────────────────────
SENTRY_DSN=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
