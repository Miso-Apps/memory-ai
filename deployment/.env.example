# ─────────────────────────────────────────────────────────────────────────────
#  Memory AI — Production Environment Variables
#  Copy to .env and fill in all values before running deploy.sh
# ─────────────────────────────────────────────────────────────────────────────

# ── Domain & SSL ──────────────────────────────────────────────────────────────
DOMAIN=api.yourdomain.com          # Your API subdomain (DNS A record → Droplet IP)
FRONTEND_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ── FastAPI App ───────────────────────────────────────────────────────────────
SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_STRING  # openssl rand -hex 32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200           # 30 days
REFRESH_TOKEN_EXPIRE_DAYS=90
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=memoryai
POSTGRES_USER=memoryai
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://memoryai:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/memoryai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD
REDIS_URL=redis://:REPLACE_WITH_REDIS_PASSWORD@redis:6379/0

# ── MinIO (object storage) ────────────────────────────────────────────────────
MINIO_ROOT_USER=memoryai
MINIO_ROOT_PASSWORD=REPLACE_WITH_MINIO_PASSWORD
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_NAME=memories
MINIO_USE_SSL=false          # true if MinIO is behind HTTPS

# Alternatively, use DigitalOcean Spaces (S3-compatible):
# MINIO_ENDPOINT=nyc3.digitaloceanspaces.com
# MINIO_ACCESS_KEY=DO_SPACES_KEY
# MINIO_SECRET_KEY=DO_SPACES_SECRET
# MINIO_BUCKET_NAME=memoryai-prod
# MINIO_USE_SSL=true

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini          # Cost-optimised for production
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Whisper (voice transcription) ────────────────────────────────────────────
WHISPER_MODEL=whisper-1            # OpenAI Whisper API (set USE_LOCAL_WHISPER=false)
USE_LOCAL_WHISPER=false

# ── Email (optional — for auth emails) ───────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
EMAIL_FROM=no-reply@yourdomain.com

# ── Sentry (optional — error tracking) ───────────────────────────────────────
SENTRY_DSN=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
